---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogList from '../components/BlogList.astro';
import { posts } from '../data/posts';
---
<BaseLayout
  title="Blog — Juan C. Gonzalez"
  description="Essays, notes, and computational experiments."
>
  <article class="page">
    <header class="page-header">
      <p class="eyebrow">Notes & essays</p>
      <h1 class="page-title">Blog</h1>
      <p class="page-lede">
        A long-form record of essays, research notes, simulations,
        and computational experiments — some polished, some still in progress.
      </p>
    </header>

    <BlogList posts={posts} />
  </article>
</BaseLayout>

<style>
  .page {
    max-width: var(--measure-wide);
    margin: 0 auto;
    padding: var(--space-16) var(--gutter) 0;
  }

  .page-header {
    border-bottom: var(--rule);
    padding-bottom: var(--space-8);
    margin-bottom: var(--space-12);
    display: grid;
    gap: var(--space-3);
  }

  .eyebrow {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-secondary);
  }

  .page-title {
    margin: 0;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(2.25rem, 5.5vw, var(--fs-2xl));
    letter-spacing: -0.025em;
    line-height: 1.02;
  }

  .page-lede {
    margin: var(--space-3) 0 0;
    font-family: var(--font-serif);
    font-size: var(--fs-md);
    line-height: 1.55;
    color: var(--color-text-secondary);
    max-width: var(--measure);
  }
</style>
