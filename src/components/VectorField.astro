---
/*
 * SVG vector field.
 *
 * A grid of arrows whose angles evolve over time according to a smooth
 * scalar field. Theme-aware via --plot-series-* tokens. Pauses when off
 * screen, freezes under prefers-reduced-motion.
 */

interface Props {
  cols?: number;
  rows?: number;
  period?: number; // seconds for one cycle
  fill?: boolean;  // if true, SVG covers its parent (height: 100%, slice)
}

const { cols = 22, rows = 14, period = 14, fill = false } = Astro.props;

const arrows: { x: number; y: number }[] = [];
for (let i = 0; i < rows; i++) {
  for (let j = 0; j < cols; j++) {
    arrows.push({ x: j, y: i });
  }
}

const viewBox = `-1 -1 ${cols + 1} ${rows + 1}`;
const preserveAspectRatio = fill ? 'xMidYMid slice' : 'xMidYMid meet';
---
<div
  class:list={['vector-field', { 'is-fill': fill }]}
  data-cols={cols}
  data-rows={rows}
  data-period={period}
>
  <svg
    viewBox={viewBox}
    preserveAspectRatio={preserveAspectRatio}
    role="img"
    aria-label="Animated vector field — a grid of arrows oriented by a smooth scalar field."
  >
    {arrows.map((a) => (
      <g
        class="arrow"
        data-x={a.x}
        data-y={a.y}
        transform={`translate(${a.x}, ${a.y})`}
      >
        <line x1="-0.35" y1="0" x2="0.30" y2="0" />
        <polyline points="0.18,-0.13 0.32,0 0.18,0.13" />
      </g>
    ))}
  </svg>
</div>

<style>
  .vector-field {
    width: 100%;
  }

  .vector-field svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .vector-field.is-fill {
    width: 100%;
    height: 100%;
  }

  .vector-field.is-fill svg {
    width: 100%;
    height: 100%;
  }

  .arrow {
    stroke: var(--plot-series-1);
    stroke-width: 0.045;
    stroke-linecap: round;
    stroke-linejoin: round;
    fill: none;
    opacity: 0.7;
  }
</style>

<script>
  type ArrowEl = SVGGElement & { __x?: number; __y?: number };

  const fields = document.querySelectorAll<HTMLDivElement>('.vector-field');
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  fields.forEach((root) => {
    const cols = Number(root.dataset.cols || 0);
    const rows = Number(root.dataset.rows || 0);
    const periodSec = Number(root.dataset.period || 14);
    const arrows = Array.from(root.querySelectorAll<ArrowEl>('.arrow'));

    // Cache coordinates on the element.
    arrows.forEach((g) => {
      g.__x = Number(g.dataset.x);
      g.__y = Number(g.dataset.y);
    });

    const cx = (cols - 1) / 2;
    const cy = (rows - 1) / 2;
    const maxR = Math.hypot(cx, cy);

    const apply = (t: number) => {
      // t is normalized: one full revolution at t = 1.
      const phase = t * Math.PI * 2;
      for (const g of arrows) {
        const x = g.__x ?? 0;
        const y = g.__y ?? 0;

        // Scalar flow: superposition of two slow sinusoids plus a slight
        // radial bias. Gives a calm, instrument-like rotation.
        const nx = (x - cx) * 0.18;
        const ny = (y - cy) * 0.18;
        const angle =
          Math.sin(nx + phase) +
          Math.cos(ny - phase * 0.7) +
          Math.atan2(ny, nx) * 0.25;

        const deg = (angle * 180) / Math.PI;

        // Subtle radial vignette via opacity.
        const r = Math.hypot(x - cx, y - cy) / (maxR || 1);
        const op = (0.85 - r * 0.45).toFixed(3);

        g.setAttribute('transform', `translate(${x}, ${y}) rotate(${deg.toFixed(2)})`);
        g.style.opacity = op;
      }
    };

    if (prefersReduced) {
      apply(0);
      return;
    }

    let raf = 0;
    let elapsed = 0;
    let last = 0;
    let running = false;

    const tick = (now: number) => {
      if (last !== 0) elapsed += now - last;
      last = now;
      apply((elapsed / 1000) / periodSec);
      raf = requestAnimationFrame(tick);
    };

    const start = () => {
      if (running) return;
      running = true;
      last = 0;
      raf = requestAnimationFrame(tick);
    };

    const stop = () => {
      if (!running) return;
      running = false;
      cancelAnimationFrame(raf);
      raf = 0;
    };

    // Render the first frame immediately so SSR-empty transforms get updated.
    apply(0);

    const io = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) start();
        else stop();
      }
    });
    io.observe(root);

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stop();
      else start();
    });
  });
</script>
